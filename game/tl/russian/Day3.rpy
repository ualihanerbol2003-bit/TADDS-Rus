translate russian jax_D3_b2eb7492:

    # j "What were you thinking, ruining everyone’s culture fair projects with meat?"
    j "Что ты вообще думал, испортив мясом проекты всех для культурного фестиваля?"

# game/Day3.rpy:10105
translate russian jax_D3_e0c21706:

    # j "You’re sick..."
    j "Ты больной..."

# game/Day3.rpy:10107
translate russian jax_D3_67aaa788:

    # "What?"
    "Что?"

# game/Day3.rpy:10109
translate russian jax_D3_419d5750:

    # a "What?"
    a "Что?"

# game/Day3.rpy:10114
translate russian jax_D3_af1a7199:

    # c "I’m very disappointed in you [avatar]."
    c "Я очень разочарован в тебе, [avatar]."

