    # a "Owwww..."
    a "Аааай..."

# game/Day3.rpy:2291
translate russian library_scavenge_5900ded1:

    # p "Sorry!"
    p "Прости!"

# game/Day3.rpy:2293
translate russian library_scavenge_eb088227:

    # "I hold her legs even tighter to steady her, which makes me blush even harder."
    "Крепче обхватываю её ноги, чтобы удержать — от этого краснею ещё сильнее."

# game/Day3.rpy:2295
translate russian library_scavenge_2eb70d05:

    # "I feel like there are heat lamps on either side of my face and I can hear my own heartbeat."
    "Кажется, что по обе стороны лица — тепловые лампы, и слышен собственный сердцебиение."

# game/Day3.rpy:2297
translate russian library_scavenge_d43cb048:

