    c "И отмени мой сеанс массажной терапии в 15:00."

# game/Day3.rpy:10195
translate russian jax_D3_37192399:

    # "He turns to face me."
    "Он оборачивается ко мне."

# game/Day3.rpy:10200
translate russian jax_D3_71d03c88:

    # c "Wait here, [avatar]."
    c "Подожди здесь, [avatar]."

# game/Day3.rpy:10202
translate russian jax_D3_657d72d7:

    # "Caine motions to the giant slug creature."
    "Кейн делает жест в сторону гигантского слизнеподобного существа."

# game/Day3.rpy:10207
