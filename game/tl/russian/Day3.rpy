    a "Э-э, нет."

# game/Day3.rpy:2282
translate russian library_scavenge_d0e50f46:

    # "We move to the next shelf, but Pomni begins to teeter atop my shoulders, almost losing balance."
    "Переходим к следующей полке, но Помни начинает покачиваться на плечах, едва не теряя равновесие."

# game/Day3.rpy:2284
translate russian library_scavenge_3ac4c501:

    # "She grasps my hair to steady herself."
    "Она хватается за волосы, чтобы удержаться."

# game/Day3.rpy:2286
