    # a "Sweet dreams, Pomni!"
    a "Сладких снов, Помни!"

# game/Dates.rpy:1112
translate russian pomni_date_f4596567:

    # "She goes back to her dorm, shutting the door behind her."
    "Она уходит к себе, закрывая дверь за собой."

# game/Dates.rpy:1114
