# game/Dates.rpy:43
translate russian pomni_date_fdc5b7df:

    # a "Yep."
    a "Ага."

# game/Dates.rpy:45
translate russian pomni_date_87d76044:

    # "I nod politely."
    "Я вежливо киваю."

# game/Dates.rpy:50
translate russian pomni_date_e423312c:

    # "There’s a moment of awkward silence as Ragatha grins at me expectantly and I just sort of"
    "На мгновение повисает неловкое молчание, Рагата выжидающе улыбается мне, а я просто"

# game/Dates.rpy:52
translate russian pomni_date_e85f4f54:

    # "Stare back."
    "Смотрю в ответ."

# game/Dates.rpy:54
translate russian pomni_date_f1ff06c7:

    # a "O-oh, I mean, yeah, maybe we can all go sometime in the future, but, I mean, umm, this is ummm..."
    a "О-ой, в смысле, да, может, мы можем все сходить туда когда-нибудь в будущем, но, в смысле, эмм, это эммм..."

# game/Dates.rpy:56
translate russian pomni_date_6f837f11:

    # a "Like a,"
    a "Типа,"

# game/Dates.rpy:58
translate russian pomni_date_a2fa9e2b:

    # a "Date? Situation?"
    a "Свидание? Встреча?"

# game/Dates.rpy:63
translate russian pomni_date_aa09f22d:

    # "Ragatha blushes, backpedalling quickly as she crosses her arms in front of her."
    "Рагата краснеет и торопливо отступает, скрещивая руки перед собой."

# game/Dates.rpy:68
translate russian pomni_date_4b3f8c33:

    # r "Oh uh, of course! I mean I wouldn’t dream of ruining your date, heh heh..."
    r "Ой эм, конечно! Я имею в виду, что у меня и в мыслях не было испортить вам свидание, хех хех..."

# game/Dates.rpy:70
translate russian pomni_date_7d068b80:

    # "She checks her wacky watch."
    "Она смотрит на свои WackyWatch."

# game/Dates.rpy:75
