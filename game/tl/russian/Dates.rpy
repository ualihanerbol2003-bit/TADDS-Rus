    a "Ну, в любом случае, я очень рад идти с тобой завтра на культурный фестиваль."

# game/Dates.rpy:1734
translate russian gan_date_8fd942c7:

    # "To myself, I resolve to confess my true feelings to her tomorrow."
    "А про себя я решаю признаться ей завтра в своих истинных чувствах."

# game/Dates.rpy:1739
translate russian gan_date_260e6c1a:

