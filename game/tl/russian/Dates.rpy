# game/Dates.rpy:1635
translate russian gan_date_c6b88dc1:

    # g "Even if it was just dealing with Jax or sitting together and watching anime."
    g "Даже когда мы просто разбирались с Джексом или сидели и смотрели аниме."

# game/Dates.rpy:1640
translate russian gan_date_c1016c4f:

    # g "I really liked every second of it."
    g "Мне правда нравилась каждая секунда."

# game/Dates.rpy:1642
translate russian gan_date_a3cf794b:

    # a "M-me too..."
    a "М-мне тоже..."

# game/Dates.rpy:1644
translate russian gan_date_a657419a:

    # a "There’s so many things I would have never tried without you,"
    a "Есть столько всего, что я бы никогда не попробовал без тебя,"

# game/Dates.rpy:1646
translate russian gan_date_da8ea97f:

    # a "like watching anime, or trying art, or even going to a maid cafe."
    a "смотреть аниме, заниматься рисованием или вот сходить в кафе горничных."

# game/Dates.rpy:1648
translate russian gan_date_9c03d78a:

    # a "You’re my favorite person here, and I want to keep spending time with you."
    a "Ты мой самый любимый человек здесь, и я хочу продолжать проводить с тобой время."

# game/Dates.rpy:1653
translate russian gan_date_3690b6c1:

    # g "[avatar], you’ve really been there for me this week."
    g "[avatar], мы правда проводили вместе время на этой неделе."

# game/Dates.rpy:1657
translate russian gan_date_4450f9b4:

    # g "You’ve really stood up for me when I need it."
    g "Ты всегда заступался за меня, когда мне это было нужно."

# game/Dates.rpy:1659
translate russian gan_date_a5e407e7:

