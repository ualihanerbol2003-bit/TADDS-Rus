    g "Хорошо спалось?"

# game/Day4.rpy:1528
translate russian gangle_D4_889f6a9a:

    # "She looks up at me."
    "Она смотрит на меня снизу вверх."

# game/Day4.rpy:1530
translate russian gangle_D4_2bf3a5fe:

    # a "Y-yeah."
    a "Д-да."

# game/Day4.rpy:1532
translate russian gangle_D4_6a5673d5:

    # "She’s so cute."
    "Она такая милая."

# game/Day4.rpy:1537
translate russian gangle_D4_fb6ed8fd:

    # g "Good."
    g "Хорошо."

# game/Day4.rpy:1539
translate russian gangle_D4_83d16038:

    # a "How did you sleep?"
    a "А ты как спала?"

# game/Day4.rpy:1544
translate russian gangle_D4_476ad492:

