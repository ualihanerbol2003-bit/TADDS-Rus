# game/Day4.rpy:1578
translate russian gangle_D4_d72af7af:

    # "Nobody takes notice of us getting in late, though neither of us can suppress quiet giggles as we take our seats."
    "Никто не замечает опоздания, хотя ни один из нас не может сдержать тихий смех, занимая места."

# game/Day4.rpy:1580
translate russian gangle_D4_3e540b59:

    # "Zooble notices."
    "Зубл замечает."

# game/Day4.rpy:1585
translate russian gangle_D4_005e912e:

    # z "What has you two so happy?"
    z "Что вас так развеселило?"

# game/Day4.rpy:1590
translate russian gangle_D4_b8d214e7:

    # g "Oh nothing."
    g "О, ничего."

# game/Day4.rpy:1592
translate russian gangle_D4_5694cdf0:

    # "Gangle flashes me a smile."
    "Гэнгл бросает мне улыбку."

