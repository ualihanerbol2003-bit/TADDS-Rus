    new "Джекс точно взял их."

    # game/Day4.rpy:639
    old "I don’t think Jax is lying."
    new "Не думаю, что Джекс врёт."

    # game/Day4.rpy:752
    old "Kinger"
    new "Королёр"

    # game/Day4.rpy:855
    old "Gangle and Zooble"
    new "Гэнгл и Зубл"

