    p "Ого, серьёзно? Куда угодно?"

# game/Day4.rpy:1394
translate russian interrogation_09feae52:

    # p "What do we pick?"
    p "Что выбрать?"

# game/Day4.rpy:1396
translate russian interrogation_bff46f85:

    # a "Well you led the investigation, Pomni, you can pick."
    a "Ну, ты вела расследование, Помни, тебе и выбирать."

# game/Day4.rpy:1401
